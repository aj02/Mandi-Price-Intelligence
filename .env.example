# data.gov.in (AGMARKNET) — get a key from https://data.gov.in (free, instant).
DATA_GOV_IN_API_KEY=
# Resource UUID for the AGMARKNET daily price dataset. Verify it on data.gov.in
# (search "Current Daily Price of Various Commodities from Various Markets (Mandi)").
# A fallback is hardcoded in src/lib/agmarknet.ts.
DATA_GOV_IN_RESOURCE_ID=

# Postgres (Supabase → Project Settings → Database)
DATABASE_URL=
DIRECT_URL=

# Upstash Redis (optional, but recommended for caching + rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Random string used to gate /api/cron/* endpoints. Generate with:
#   openssl rand -hex 32
CRON_SECRET=

# DeepInfra (Llama 3.3 70B for daily commentary). Skip to disable the commentary card.
DEEPINFRA_API_KEY=

# Public site URL — used by sitemap/og.
NEXT_PUBLIC_SITE_URL=https://mandi-mitra.vercel.app
